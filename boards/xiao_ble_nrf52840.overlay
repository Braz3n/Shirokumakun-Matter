/*
 * Devicetree overlay for Seeed XIAO BLE — Matter AC Controller
 *
 * - Disable USB (save RAM, we use J-Link + RTT)
 * - Reclaim flash from SoftDevice + bootloader
 * - Disable Zephyr PWM0 (IR driver uses NRF_PWM0 registers directly)
 * - I2C0 (TWIM0) for SCD40 sensor (P0.04 SDA / P0.05 SCL)
 */

/* Remap I2C0 pins to P0.04/P0.05 (board default is P0.07/P0.27 for
 * the Sense variant's IMU) and enable internal pull-ups. */
&pinctrl {
    i2c0_default: i2c0_default {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
            bias-pull-up;
        };
    };
    i2c0_sleep: i2c0_sleep {
        group1 {
            psels = <NRF_PSEL(TWIM_SDA, 0, 4)>,
                    <NRF_PSEL(TWIM_SCL, 0, 5)>;
            low-power-enable;
        };
    };
};

&i2c0 {
    status = "okay";
    clock-frequency = <I2C_BITRATE_STANDARD>;
    pinctrl-0 = <&i2c0_default>;
    pinctrl-1 = <&i2c0_sleep>;
    pinctrl-names = "default", "sleep";
};

/* USB-CDC: shell on ACM0 (usb_cdc_acm_uart, via board DTS), SMP/DFU on ACM1 */
&usbd {
    status = "okay";
    cdc_acm_uart1: cdc_acm_uart1 {
        compatible = "zephyr,cdc-acm-uart";
    };
};

/* Replace Adafruit-layout partitions with MCUboot-compatible labels.
 * Addresses must match pm_static_xiao_ble_nrf52840_sense.yml.
 * image_signing.cmake needs slot0_partition to determine the slot size. */
&flash0 {
    /delete-node/ partitions;

    partitions {
        compatible = "fixed-partitions";
        #address-cells = <1>;
        #size-cells = <1>;

        boot_partition: partition@0 {
            label = "mcuboot";
            reg = <0x00000000 0x00010000>;
        };

        slot0_partition: partition@10000 {
            label = "image-0";
            reg = <0x00010000 0x000E0000>;
        };

        storage_partition: partition@f0000 {
            label = "storage";
            reg = <0x000F0000 0x00010000>;
        };
    };
};

/ {
    chosen {
        zephyr,code-partition = &slot0_partition;
        zephyr,uart-mcumgr = &cdc_acm_uart1;
        nordic,pm-ext-flash = &p25q16h;
    };
};

/* Disable Zephyr PWM0 — the IR driver configures NRF_PWM0 registers
 * directly to work around the polarity trick needed for 0% duty. */
&pwm0 { status = "disabled"; };
